{
  "name": "ueblueprint",
  "description": "Unreal Engine's Blueprint visualization web library",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/ueblueprint.js",
  "types": "types.js",
  "scripts": {
    "build": "vite build && vite build --mode minified && sass scss/export.scss:dist/css/ueb-style.css && sass scss/export.scss:dist/css/ueb-style.min.css --style=compressed",
    "start": "vite --host 127.0.0.1",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barsdeveloper/ueblueprint.git"
  },
  "keywords": [
    "unreal",
    "engine",
    "blueprint"
  ],
  "author": "barsdeveloper",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/barsdeveloper/ueblueprint/issues"
  },
  "homepage": "https://github.com/barsdeveloper/ueblueprint#readme",
  "devDependencies": {
    "@playwright/test": "1.49",
    "concurrently": "^9",
    "sass": "^1",
    "terser": "^5",
    "vite": "^7",
    "vitest": "^3"
  },
  "dependencies": {
    "lit": "^3",
    "parsernostrum": "^1"
  }
}
