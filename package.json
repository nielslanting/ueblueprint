{
  "name": "ueblueprint-workspace",
  "description": "Unreal Engine's Blueprint visualization web library",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/parser",
    "packages/lit"
  ],
  "scripts": {
    "build": "npm run build -w @ueblueprint/parser && npm run build -w @ueblueprint/lit",
    "dev": "npm run dev -w @ueblueprint/lit",
    "start": "npm run start -w @ueblueprint/lit",
    "test": "npm run test -w @ueblueprint/parser && npm run test -w @ueblueprint/lit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barsdeveloper/ueblueprint.git"
  },
  "keywords": [
    "unreal",
    "engine",
    "blueprint"
  ],
  "author": "barsdeveloper",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/barsdeveloper/ueblueprint/issues"
  },
  "homepage": "https://github.com/barsdeveloper/ueblueprint#readme",
  "devDependencies": {
    "@playwright/test": "1.49",
    "concurrently": "^9",
    "sass": "^1",
    "terser": "^5",
    "vite": "^7",
    "vitest": "^3"
  }
}
